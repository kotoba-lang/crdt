(ns kotoba.crdt.orset-conformance
  (:require [kotoba.crdt.orset :as orset])
  (:export [main]))

(def tag-type
  [:record :kotoba.crdt/stamp [[:counter :i64] [:actor :i64]]])
(def orset-type
  [:record :kotoba.crdt/orset-i64-v1
   [[:adds
     [:map :i64
      [:map [:record :kotoba.crdt/stamp [[:counter :i64] [:actor :i64]]] :bool]]]
    [:tombstones
     [:map [:record :kotoba.crdt/stamp [[:counter :i64] [:actor :i64]]] :bool]]]])

(defn main
  [] :i64
  (let [tag-a (record tag-type 1 1)
        tag-b (record tag-type 1 2)
        tag-c (record tag-type 2 1)
        a (orset/add (orset/init) 10 tag-a)
        b-added (orset/add (orset/init) 10 tag-b)
        b (orset/remove-tags b-added (orset/observed-tags b-added 10))
        c (orset/add (orset/init) 20 tag-c)
        ab (orset/merge-orset a b)
        ba (orset/merge-orset b a)
        left (orset/merge-orset (orset/merge-orset a b) c)
        right (orset/merge-orset a (orset/merge-orset b c))]
    (if (orset/contains-elem? ab 10)
      (if (record-equal orset-type ab ba)
        (if (record-equal orset-type (orset/merge-orset a a) a)
          (if (record-equal orset-type left right) 42 3)
          2)
        1)
      0)))
