(ns kotoba.crdt.register-conformance
  (:require [kotoba.crdt.register :as register])
  (:export [main]))

(defn main [] :i64
  (let [empty (register/init)
        earlier
        (option-some-of
          [:option [:record :kotoba.crdt/string-register
                    [[:value :string]
                     [:stamp [:record :kotoba.crdt/stamp
                              [[:counter :i64] [:actor :i64]]]]]]]
          (register/write "red"
            (record [:record :kotoba.crdt/stamp [[:counter :i64] [:actor :i64]]]
                    1 10)))
        later
        (option-some-of
          [:option [:record :kotoba.crdt/string-register
                    [[:value :string]
                     [:stamp [:record :kotoba.crdt/stamp
                              [[:counter :i64] [:actor :i64]]]]]]]
          (register/write "blue"
            (record [:record :kotoba.crdt/stamp [[:counter :i64] [:actor :i64]]]
                    2 20)))
        winner (register/merge-register earlier later)
        reverse-winner (register/merge-register later earlier)
        empty-left (register/merge-register empty later)
        empty-right (register/merge-register later empty)]
    (if (string=? "blue"
          (register/value
            (option-value-of
              [:option [:record :kotoba.crdt/string-register
                        [[:value :string]
                         [:stamp [:record :kotoba.crdt/stamp
                                  [[:counter :i64] [:actor :i64]]]]]]]
              winner (register/write "invalid"
                       (record [:record :kotoba.crdt/stamp
                                [[:counter :i64] [:actor :i64]]] 0 1)))))
      (if (string=? "blue"
            (register/value
              (option-value-of
                [:option [:record :kotoba.crdt/string-register
                          [[:value :string]
                           [:stamp [:record :kotoba.crdt/stamp
                                    [[:counter :i64] [:actor :i64]]]]]]]
                reverse-winner (register/write "invalid"
                                 (record [:record :kotoba.crdt/stamp
                                          [[:counter :i64] [:actor :i64]]] 0 1)))))
        (if (option-some?-of
              [:option [:record :kotoba.crdt/string-register
                        [[:value :string]
                         [:stamp [:record :kotoba.crdt/stamp
                                  [[:counter :i64] [:actor :i64]]]]]]]
              empty-left)
          (if (option-some?-of
                [:option [:record :kotoba.crdt/string-register
                          [[:value :string]
                           [:stamp [:record :kotoba.crdt/stamp
                                    [[:counter :i64] [:actor :i64]]]]]]]
                empty-right)
            42
            0)
          0)
        0)
      0)))
