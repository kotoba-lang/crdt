(ns kotoba.crdt.clock-conformance
  (:require [kotoba.crdt.clock :as clock])
  (:export [main]))

(defn main [] :i64
  (let [initial (clock/init 7)
        advanced (clock/tick initial)
        observed
        (clock/observe advanced
          (record [:record :kotoba.crdt/stamp [[:counter :i64] [:actor :i64]]]
                  5 9))
        alice
        (record [:record :kotoba.crdt/stamp [[:counter :i64] [:actor :i64]]]
                1 10)
        bob
        (record [:record :kotoba.crdt/stamp [[:counter :i64] [:actor :i64]]]
                1 20)]
    (if (and
          (if (= 6 (record-get
                     [:record :kotoba.crdt/clock [[:counter :i64] [:actor :i64]]]
                     observed :counter))
            true
            false)
          (clock/before? alice bob)
          (if (clock/before? bob alice) false true))
      42
      0)))
