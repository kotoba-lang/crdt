(ns kotoba.crdt.doc-conformance
  (:require [kotoba.crdt.doc :as doc])
  (:export [main]))

(def stamp-type
  [:record :kotoba.crdt/stamp [[:counter :i64] [:actor :i64]]])
(def tag-map-type
  [:map [:record :kotoba.crdt/stamp [[:counter :i64] [:actor :i64]]] :bool])
(def orset-type
  [:record :kotoba.crdt/orset-i64-v1
   [[:adds [:map :i64 [:alias tag-map-type]]] [:tombstones [:alias tag-map-type]]]])
(def register-type
  [:record :kotoba.crdt/string-register [[:value :string] [:stamp [:alias stamp-type]]]])
(def field-map-type [:map :keyword [:alias register-type]])
(def fields-type [:map :i64 [:alias field-map-type]])
(def doc-type
  [:record :kotoba.crdt/string-document-v1
   [[:entities [:alias orset-type]] [:fields [:alias fields-type]]]])
(def add-payload-type [:vector [:i64 [:alias stamp-type]]])
(def remove-payload-type [:vector [[:alias tag-map-type]]])
(def set-payload-type [:vector [:i64 :keyword :string [:alias stamp-type]]])
(def op-type
  [:variant :kotoba.crdt/string-document-op-v1
   [[:add [:alias add-payload-type]]
    [:remove [:alias remove-payload-type]]
    [:set-field [:alias set-payload-type]]]])

(defn main
  [] :i64
  (let [stamp-a (record stamp-type 1 1)
        stamp-b (record stamp-type 2 2)
        add-a (variant-new op-type :add
                (hetero-vector add-payload-type 10 stamp-a))
        add-b (variant-new op-type :add
                (hetero-vector add-payload-type 10 stamp-b))
        set-a (variant-new op-type :set-field
                (hetero-vector set-payload-type 10 :title "left" stamp-a))
        set-b (variant-new op-type :set-field
                (hetero-vector set-payload-type 10 :title "right" stamp-b))
        a (doc/apply-op (doc/apply-op (doc/init) add-a) set-a)
        b (doc/apply-op (doc/apply-op (doc/init) add-b) set-b)
        ab (doc/merge-docs a b)
        ba (doc/merge-docs b a)
        left (doc/merge-docs (doc/merge-docs a b) (doc/init))
        right (doc/merge-docs a (doc/merge-docs b (doc/init)))
        replay (doc/apply-op (doc/apply-op a set-b) set-b)]
    (if (doc/contains-entity? ab 10)
      (match-option (doc/get-field ab 10 :title) [:option :string]
        (none 0)
        (some title
          (if (string=? title "right")
            (if (record-equal doc-type ab ba)
              (if (record-equal doc-type left right)
                (if (record-equal doc-type (doc/merge-docs a a) a)
                  (if (record-equal doc-type replay (doc/apply-op a set-b)) 42 5)
                  4)
                3)
              2)
            1)))
      0)))
